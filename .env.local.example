# ───────────────────────────────────────────────────────────
# Supabase — siznig loyihangizdagi qiymatlarni qo'ying
# Project Settings → API + Database
# ───────────────────────────────────────────────────────────

# Postgres connection string (Database → Connection string → URI)
# Format: postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres.xxxx:password@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# Direct (non-pooled) connection — Drizzle migrations uchun
# Format: postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres
DATABASE_URL_DIRECT=postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres

# Public anon key — clientda ishlatiladi (Storage, realtime uchun)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...

# Service role key — faqat serverda (RLS bypass). HECH QACHON clientga oshkor qilmang.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# ───────────────────────────────────────────────────────────
# better-auth
# ───────────────────────────────────────────────────────────

# 32+ belgili random secret (`openssl rand -base64 32`)
BETTER_AUTH_SECRET=replace-with-random-32-byte-secret

# Auth callback URL (production'da real domen, masalan https://neyrocog.uz)
BETTER_AUTH_URL=http://localhost:3000

# Ixtiyoriy: qo'shimcha ishonchli originlar (vergul bilan ajratilgan) —
# preview deploylar yoki maxsus domen uchun.
# AUTH_TRUSTED_ORIGINS=https://www.neyrocog.uz,https://neyrocog.vercel.app

# ───────────────────────────────────────────────────────────
# Resend — parol tiklash emaillari uchun (keyinroq)
# ───────────────────────────────────────────────────────────
# RESEND_API_KEY=
